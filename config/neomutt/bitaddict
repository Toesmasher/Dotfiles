# vi: set ft=neomuttrc :
set from = "niklas.berggren@bitaddict.se"
set real_name = "Niklas Berggren"
set my_pass = "`pass bitaddict/mail/password`"
set my_secret = "`pass bitaddict/mail/secret`"
set my_smtp_refresh_token="`pass bitaddict/mail/token`"

set folder = "~/.mail/bitaddict"
set mbox_type = "Maildir"

# SMTP
set smtp_url = "smtps://smtp.gmail.com:465"
set smtp_user = "niklas.berggren@bitaddict.se"
set smtp_authenticators="oauthbearer"
set smtp_oauth_refresh_command="python ~/.config/neomutt/tokens/oauth2.py \
  --quiet \
  --user=niklas.berggren@bitaddict.se \
  --client_id=419635704791-e8ouna7jgofh7jr0v8hsds1ct0tbfalu.apps.googleusercontent.com \
  --client_secret=$my_secret \
  --refresh_token=$my_smtp_refresh_token"

set spool_file = "+INBOX"
set record = "+[Gmail].Sent Mail"
set trash = "+[Gmail].Trash"
set postponed = "+[Gmail].Drafts"

mailboxes ="INBOX" ="[Gmail].All Mail" ="[Gmail].Drafts" ="[Gmail].Sent Mail" \
          ="[Gmail].Spam" ="[Gmail].Trash"

source $HOME/.config/neomutt/common
